{
  "manifest_version": 3,
  "name": "Checkmate",
  "version": "1.0.0",
  "description": "Real-time move suggestions for Chess.com",
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "permissions": ["activeTab", "scripting", "tabs", "offscreen", "storage"],
  "host_permissions": ["https://www.chess.com/*"],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": ["worker/stockfish.js", "worker/stockfish.wasm", "worker/stockfish-worker.js", "worker/stockfish.worker.js"],
      "matches": ["https://www.chess.com/*"]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.chess.com/*"],
      "js": [
        "common/status-model.js",
        "content/board-reader.js",
        "content/move-renderer.js",
        "content/toggle-ui.js",
        "content/content.js"
      ]
    }
  ]
}
